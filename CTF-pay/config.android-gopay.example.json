          "timeout_s": 20
        },
        {
          "action": "tap",
          "text": "Unlink",
          "timeout_s": 20
        },
        {
          "action": "sleep",
          "seconds": 1
        },
        {
          "action": "tap",
          "text": "Unlink",
          "timeout_s": 20
        },
        {
          "action": "assert_text_any",
          "values": [
            "Successfully unlinked",
            "No apps linked to your GoPay"
          ],
          "timeout_s": 20
