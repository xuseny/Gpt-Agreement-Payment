{
  "gopay": {
    "country_code": "62",
    "phone_number": "81234567890",
    "pin": "YOUR_6_DIGIT_GOPAY_PIN",
    "otp_validate_retry_limit": 2,
    "otp_validate_retry_sleep_s": 1,
    "otp": {
      "source": "command",
      "command": [
        "python",
        "CTF-pay/android_gopay_automation.py",
        "--config",
        "CTF-pay/config.android-gopay.example.json",
        "otp"
      ],
      "timeout": 300,
      "interval": 2,
      "issued_after_slack_s": 2,
      "code_regex": "(?<!\\d)(\\d{6})(?!\\d)"
    }
  },
  "phone_worker": {
    "server_base_url": "https://YOUR_WEBUI_DOMAIN_OR_IP",
    "relay_token": "FILL_FROM_SERVER_RELAY_TOKEN",
    "push_path": "/api/whatsapp/sidecar/state",
    "notification_source": "adb",
    "poll_interval_s": 2,
    "post_timeout_s": 10,
    "dedupe_window_s": 180,
    "push_delay_after_notification_s": 20,
    "ignore_existing_on_start": true,
    "state_file": "output/android-phone-worker-state.json",
    "set_proxy_on_start": true,
    "clear_proxy_on_exit": false,
    "otp_focus": {
      "enabled": true,
      "package": "com.whatsapp",
      "focus_on_notification": true,
      "notification_keywords": [
        "gopay",
        "gojek",
        "otp",
        "one-time",
        "one time",
        "password",
        "kode",
        "verifikasi",
        "verification",
        "code"
      ],
      "start_wait_s": 1
    },
    "gopay_unlink": {
      "enabled": true,
      "run_logs_path": "/api/run/sidecar/logs",
      "trigger_strings": [
        "GoPay \u6388\u6743 + \u6263\u6b3e\u5b8c\u6210"
      ],
      "ignore_existing_run_logs_on_start": true,
      "poll_interval_s": 2,
      "out_dir": "output/android-gopay-unlink",
      "timeout_s": 120,
      "delay_after_trigger_s": 0
    }
  },
  "android_automation": {
    "adb_path": "adb",
    "adb_serial": "3B65AA01QGE00000",
    "appium_server_url": "http://127.0.0.1:4723",
    "device_name": "Android Phone",
    "capabilities": {
      "platformName": "Android",
      "automationName": "UiAutomator2",
      "noReset": true,
      "newCommandTimeout": 300
    },
    "implicit_wait_s": 0.2,
    "screen": {
      "enabled": true,
      "screen_off_timeout_ms": 2147483647,
      "keepalive_interval_s": 30,
      "wake_on_start": true,
      "dismiss_keyguard": true,
      "set_stay_on_while_plugged": true,
      "stay_on_while_plugged_in": 3,
      "set_screen_off_timeout": true
    },
    "proxy": {
      "enabled": false,
      "host_port": "127.0.0.1:18898",
      "pool": [
        "127.0.0.1:18898",
        {
          "host": "127.0.0.1",
          "port": 18899
        },
        "http://user:pass@127.0.0.1:18900"
      ],
      "clear_on_exit": false
    },
    "otp": {
      "notification_source": "adb",
      "timeout_s": 300,
      "poll_interval_s": 2,
      "package_filters": [
        "com.whatsapp"
      ],
      "keywords": [
        "gopay",
        "gojek",
        "whatsapp",
        "otp",
        "kode",
        "verifikasi",
        "verification",
        "code"
      ],
      "code_regex": "(?<!\\d)(\\d{6})(?!\\d)"
    },
    "gopay_unlink": {
      "package": "com.gojek.gopay",
      "activity": "",
      "start_wait_s": 3,
      "activate_wait_s": 2,
      "state_max_iterations": 30,
      "state_settle_s": 0.7,
      "states": [
        {
          "name": "already_unlinked",
          "match_any": [
            "Successfully unlinked",
            "No apps linked to your GoPay"
          ],
          "terminal": true,
          "dump_on_enter": true,
          "terminal_steps": [
            {
              "action": "dump",
              "name": "before_exit_linked_apps"
            },
            {
              "action": "back"
            },
            {
              "action": "sleep",
              "seconds": 0.5
            },
            {
              "action": "back"
            },
            {
              "action": "sleep",
              "seconds": 0.3
            },
            {
              "action": "press_keycode",
              "keycode": 3
            }
          ]
        },
        {
          "name": "unlink_confirm",
          "match_all": [
            "Unlink"
          ],
          "match_any": [
            "Cancel",
            "Are you sure",
            "disconnect",
            "konfirmasi"
          ],
          "steps": [
            {
              "action": "tap",
              "text": "Unlink",
              "timeout_s": 6
            }
          ]
        },
        {
          "name": "linked_app_detail",
          "match_any": [
            "Unlink"
          ],
          "steps": [
            {
              "action": "tap",
              "text": "Unlink",
              "timeout_s": 8
            }
          ]
        },
        {
          "name": "linked_apps",
          "match_any": [
            "Linked apps",
            "Aplikasi tertaut"
          ],
          "steps": [
            {
              "action": "tap",
              "text_contains": "Linked apps",
              "timeout_s": 8
            }
          ]
        },
        {
          "name": "profile_settings",
          "match_any": [
            "Account & app settings",
            "Pengaturan akun"
          ],
          "steps": [
            {
              "action": "tap",
              "text_contains": "Account & app settings",
              "timeout_s": 8
            }
          ]
        },
        {
          "name": "profile_tab",
          "match_any": [
            "Profile",
            "Profil"
          ],
          "steps": [
            {
              "action": "tap",
              "text_contains": "Profile",
              "timeout_s": 5
            }
          ]
        },
        {
          "name": "unknown_back",
          "default": true,
          "dump_on_enter": true,
          "max_visits": 3,
          "steps": [
            {
              "action": "back"
            }
          ]
        }
      ],
      "steps": [
        {
          "action": "dump",
          "name": "start"
        },
        {
          "action": "tap_optional",
          "text_contains": "Profile",
          "timeout_s": 4
        },
        {
          "action": "tap_optional",
          "text_contains": "Account & app settings",
          "timeout_s": 6
        },
        {
          "action": "back_if_text_any",
          "values": [
            "No apps linked to your GoPay",
            "Successfully unlinked"
          ],
          "timeout_s": 1
        },
        {
          "action": "tap_optional",
          "text_contains": "Account & app settings",
          "timeout_s": 3
        },
        {
          "action": "tap",
          "text_contains": "Linked apps",
          "timeout_s": 20
        },
        {
          "action": "tap",
          "text": "Unlink",
          "timeout_s": 20
        },
        {
          "action": "sleep",
          "seconds": 1
        },
        {
          "action": "tap",
          "text": "Unlink",
          "timeout_s": 20
        },
        {
          "action": "assert_text_any",
          "values": [
            "Successfully unlinked",
            "No apps linked to your GoPay"
          ],
          "timeout_s": 20
        },
        {
          "action": "dump",
          "name": "after_unlink"
        }
      ]
    }
  },
  "fresh_checkout": {
    "auth": {
      "cookie_header": "",
      "session_token": "",
      "access_token": "",
      "device_id": "",
      "mode": "access_token"
    }
  },
  "runtime": {
    "confirm_mode": "shared_payment_method",
    "version": "fed52f3bc6",
    "js_checksum": "FILL_FROM_CURRENT_STRIPE_CHECKOUT",
    "rv_timestamp": "FILL_FROM_CURRENT_STRIPE_CHECKOUT"
  },
  "proxy": ""
}
