          "dump_on_enter": true,
          "max_visits": 3,
          "steps": [
            {
              "action": "back"
            }
          ]
        }
      ],
      "steps": [
        {
          "action": "dump",
          "name": "start"
        },
        {
          "action": "tap_optional",
          "text_contains": "Profile",
          "timeout_s": 4
        },
        {
          "action": "tap_optional",
          "text_contains": "Account & app settings",
          "timeout_s": 6
