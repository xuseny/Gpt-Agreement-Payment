        },
        {
          "name": "account_safety_id",
          "match_all": [
            "Pengaturan akun"
          ],
          "match_none": [
            "Aplikasi tertaut"
          ],
          "steps": [
            {
              "action": "tap_source_text",
              "text_any": [
                "Account & app settings",
                "Pengaturan akun"
              ],
              "match_mode": "prefix",
              "clickable_only": true,
              "exclude_heading": true,
              "min_y_ratio": 0.12,
              "row_center_x": true,
              "timeout_s": 5
            }
          ]
        },
        {
          "name": "home",
          "match_all": [
            "Home",
            "Finance",
            "QRIS",
            "History",
            "Profile"
          ],
          "match_none": [
            "Account & safety",
            "Account & app settings",
            "Linked apps"
          ],
          "steps": [
            {
              "action": "tap_source_text",
              "text_any": [
