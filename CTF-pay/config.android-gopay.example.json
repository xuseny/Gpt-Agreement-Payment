    "gopay_unlink": {
      "package": "com.gojek.gopay",
      "activity": "",
      "start_wait_s": 3,
      "activate_wait_s": 2,
      "state_max_iterations": 30,
      "state_settle_s": 0.7,
      "state_detect_timeout_s": 5,
      "exit_to_home_on_complete": false,
      "states": [
        {
          "name": "already_unlinked",
          "match_any": [
            "Successfully unlinked",
            "No apps linked to your GoPay"
          ],
          "terminal": true,
          "dump_on_enter": true,
          "terminal_steps": [
            {
              "action": "dump",
              "name": "before_exit_linked_apps"
            },
            {
              "action": "back"
            },
            {
              "action": "sleep",
              "seconds": 0.5
            },
            {
              "action": "wait_text_any",
              "values": [
                "Account & app settings",
                "Pengaturan akun"
              ],
              "timeout_s": 15
            }
          ]
        },
        {
          "name": "unlink_confirm",
          "match_all": [
            "Unlink"
          ],
          "match_any": [
            "Cancel",
            "Are you sure",
            "Unlink OpenAI",
            "Once unlinked",
            "disconnect",
            "konfirmasi"
          ],
          "steps": [
            {
              "action": "tap_source_text",
              "text": "Unlink",
              "clickable_only": true,
              "min_y_ratio": 0.65,
              "timeout_s": 6
            }
          ]
        },
        {
          "name": "linked_apps",
          "match_all": [
            "Linked apps",
            "OpenAI LLC",
            "Linked on",
            "Unlink"
          ],
          "match_none": [
            "Account & app settings",
            "Pengaturan akun",
            "Popular service permission",
            "No apps linked to your GoPay"
          ],
          "steps": [
            {
              "action": "tap_source_text",
              "text": "Unlink",
              "clickable_only": true,
              "min_y_ratio": 0.12,
              "max_y_ratio": 0.45,
              "timeout_s": 8
            }
          ]
        },
        {
          "name": "linked_apps_open_detail",
          "match_any": [
            "Linked apps",
            "Aplikasi tertaut"
          ],
          "match_none": [
            "Account & app settings",
            "Pengaturan akun",
            "Unlink",
            "No apps linked to your GoPay"
          ],
          "steps": [
            {
              "action": "tap_source_text",
              "text_any": [
                "Linked apps",
                "Aplikasi tertaut"
              ],
              "match_mode": "prefix",
              "clickable_only": true,
              "exclude_heading": true,
              "min_y_ratio": 0.18,
              "row_center_x": true,
              "timeout_s": 8
            }
          ]
        },
        {
          "name": "linked_app_detail",
