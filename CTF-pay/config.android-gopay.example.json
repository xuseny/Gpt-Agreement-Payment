{
  "gopay": {
    "country_code": "62",
    "phone_number": "81234567890",
    "pin": "YOUR_6_DIGIT_GOPAY_PIN",
    "otp_validate_retry_limit": 2,
    "otp_validate_retry_sleep_s": 1,
    "otp": {
      "source": "command",
      "command": [
        "python",
        "CTF-pay/android_gopay_automation.py",
        "--config",
        "CTF-pay/config.android-gopay.example.json",
        "otp"
      ],
      "timeout": 300,
      "interval": 2,
      "issued_after_slack_s": 2,
      "code_regex": "(?<!\\d)(\\d{6})(?!\\d)"
    }
  },
  "phone_worker": {
    "server_base_url": "https://YOUR_WEBUI_DOMAIN_OR_IP",
    "relay_token": "FILL_FROM_SERVER_RELAY_TOKEN",
    "push_path": "/api/whatsapp/sidecar/state",
    "notification_source": "adb",
    "poll_interval_s": 2,
    "post_timeout_s": 10,
    "dedupe_window_s": 180,
    "ignore_existing_on_start": true,
    "state_file": "output/android-phone-worker-state.json",
    "set_proxy_on_start": true,
    "clear_proxy_on_exit": false
  },
  "android_automation": {
    "adb_path": "adb",
    "adb_serial": "3B65AA01QGE00000",
    "appium_server_url": "http://127.0.0.1:4723",
    "device_name": "Android Phone",
    "capabilities": {
      "platformName": "Android",
      "automationName": "UiAutomator2",
      "noReset": true,
      "newCommandTimeout": 300
    },
    "proxy": {
      "enabled": false,
      "host_port": "127.0.0.1:18898",
      "pool": [
        "127.0.0.1:18898",
        {
          "host": "127.0.0.1",
          "port": 18899
        },
        "http://user:pass@127.0.0.1:18900"
      ],
      "clear_on_exit": false
    },
    "otp": {
      "notification_source": "adb",
      "timeout_s": 300,
      "poll_interval_s": 2,
      "package_filters": [
        "com.whatsapp"
      ],
      "keywords": [
        "gopay",
        "gojek",
        "whatsapp",
        "otp",
        "kode",
        "verifikasi",
        "verification",
        "code"
      ],
      "code_regex": "(?<!\\d)(\\d{6})(?!\\d)"
    },
    "gopay_unlink": {
      "package": "com.gojek.app",
      "activity": "",
      "steps": [
        {
          "action": "dump",
          "name": "start"
        }
      ]
    }
  },
  "fresh_checkout": {
    "auth": {
      "cookie_header": "",
      "session_token": "",
      "access_token": "",
      "device_id": "",
      "mode": "access_token"
    }
  },
  "runtime": {
    "confirm_mode": "shared_payment_method",
    "version": "fed52f3bc6",
    "js_checksum": "FILL_FROM_CURRENT_STRIPE_CHECKOUT",
    "rv_timestamp": "FILL_FROM_CURRENT_STRIPE_CHECKOUT"
  },
  "proxy": ""
}
