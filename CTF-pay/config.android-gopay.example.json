{
  "gopay": {
    "country_code": "62",
    "phone_number": "81234567890",
    "pin": "YOUR_6_DIGIT_GOPAY_PIN",
    "otp_validate_retry_limit": 2,
    "otp_validate_retry_sleep_s": 1,
    "otp": {
      "source": "command",
      "command": [
        "python",
        "CTF-pay/android_gopay_automation.py",
        "--config",
        "CTF-pay/config.android-gopay.example.json",
        "otp"
      ],
      "timeout": 300,
      "interval": 2,
      "issued_after_slack_s": 2,
      "code_regex": "(?<!\\d)(\\d{6})(?!\\d)"
    }
  },
  "phone_worker": {
    "server_base_url": "https://YOUR_WEBUI_DOMAIN_OR_IP",
    "relay_token": "FILL_FROM_SERVER_RELAY_TOKEN",
    "push_path": "/api/whatsapp/sidecar/state",
    "notification_source": "adb",
    "poll_interval_s": 2,
    "post_timeout_s": 10,
    "dedupe_window_s": 180,
    "push_delay_after_notification_s": 20,
    "ignore_existing_on_start": true,
    "state_file": "output/android-phone-worker-state.json",
    "set_proxy_on_start": true,
    "clear_proxy_on_exit": false,
    "otp_focus": {
      "enabled": true,
      "package": "com.whatsapp",
      "focus_on_notification": true,
      "notification_keywords": [
        "gopay",
        "gojek",
        "otp",
        "one-time",
        "one time",
        "password",
        "kode",
        "verifikasi",
        "verification",
        "code"
      ],
      "start_wait_s": 1,
      "focus_on_run_log": true,
      "run_log_trigger_strings": [
        "[gopay] waiting WhatsApp OTP",
        "[gopay] requesting WhatsApp OTP",
        "waiting WhatsApp OTP from relay",
        "waiting WhatsApp OTP from file",
        "waiting WhatsApp OTP from command",
        "GOPAY_OTP_REQUEST",
        "gopay&&whatsapp&&otp"
      ]
    },
    "gopay_unlink": {
      "enabled": true,
      "run_logs_path": "/api/run/sidecar/logs",
      "trigger_strings": [
        "GoPay \u6388\u6743 + \u6263\u6b3e\u5b8c\u6210",
        "GoPay&&\u6388\u6743&&\u6263\u6b3e&&\u5b8c\u6210",
        "GoPay&&poll&&\u7ed3\u679c"
      ],
      "ignore_existing_run_logs_on_start": true,
      "poll_interval_s": 2,
      "out_dir": "output/android-gopay-unlink",
      "timeout_s": 120,
      "delay_after_trigger_s": 0
    }
  },
  "android_automation": {
    "adb_path": "adb",
    "adb_serial": "auto",
    "emulator": "mumu",
    "adb_connect_serials": [
      "127.0.0.1:16416",
      "127.0.0.1:5557",
      "127.0.0.1:16384",
      "127.0.0.1:7555"
    ],
    "appium_server_url": "http://127.0.0.1:4723",
    "device_name": "MuMu Android",
    "capabilities": {
      "platformName": "Android",
      "automationName": "UiAutomator2",
      "noReset": true,
      "newCommandTimeout": 300
    },
    "implicit_wait_s": 0.2,
    "screen": {
      "enabled": true,
      "screen_off_timeout_ms": 2147483647,
      "keepalive_interval_s": 30,
      "wake_on_start": true,
      "dismiss_keyguard": true,
      "set_stay_on_while_plugged": true,
      "stay_on_while_plugged_in": 3,
      "set_screen_off_timeout": true
    },
    "proxy": {
      "enabled": false,
      "host_port": "127.0.0.1:18898",
      "pool": [
        "127.0.0.1:18898",
        {
          "host": "127.0.0.1",
          "port": 18899
        },
        "http://user:pass@127.0.0.1:18900"
      ],
      "clear_on_exit": false
    },
    "otp": {
      "notification_source": "adb",
      "timeout_s": 300,
      "poll_interval_s": 2,
      "package_filters": [
        "com.whatsapp"
      ],
      "keywords": [
        "gopay",
        "gojek",
        "whatsapp",
        "otp",
        "kode",
        "verifikasi",
        "verification",
        "code"
      ],
      "code_regex": "(?<!\\d)(\\d{6})(?!\\d)"
