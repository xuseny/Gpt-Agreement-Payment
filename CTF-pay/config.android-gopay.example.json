            {
              "action": "tap_source_text",
              "text_any": [
                "Linked apps",
                "Aplikasi tertaut"
              ],
              "match_mode": "prefix",
              "clickable_only": true,
              "exclude_heading": true,
              "min_y_ratio": 0.18,
              "row_center_x": true,
              "timeout_s": 8
            }
          ]
        },
        {
